            "type": "string"
          },
          "endsAt": {
            "type": "string"
          },
          "allDay": {
            "type": "boolean"
          },
          "timezone": {
            "description": "TZID from DTSTART, when present.",
            "type": "string"
          },
          "organizer": {
            "$ref": "#/components/schemas/Contact"
          },
          "userIsAttendee": {
            "description": "True when the current user's personal email matches an ATTENDEE on the iTIP payload.",
            "type": "boolean"
          },
          "userResponseStatus": {
            "description": "Short PARTSTAT code for the current user. Present iff userIsAttendee.",
            "type": "string",
            "enum": ["NA", "AC", "DE", "TE"]
          },
          "matchExistingEvent": {
            "description": "Pointer to an existing event with the same UID, when one exists in the user's calendars. Null otherwise.",
            "$ref": "#/components/schemas/MatchedEvent"
          },
          "replyAttendee": {
            "description": "For method=REPLY only: the attendee whose response this REPLY carries.",
            "$ref": "#/components/schemas/Contact"
          },
          "replyStatus": {
            "description": "For method=REPLY only: short PARTSTAT code (NA/AC/DE/TE) carried by the REPLY.",
            "type": "string",
            "enum": ["NA", "AC", "DE", "TE"]
          },
          "comment": {
            "description": "Optional COMMENT property value from the VEVENT.",
            "type": "string"
          }
        }
      },
