      "CalendarPart": {
        "title": "CalendarPart",
        "description": "Parsed view of a text/calendar (or application/ics) attachment carrying an iTIP payload.",
        "type": "object",
        "properties": {
          "attachmentIndex": {
            "description": "Zero-based index into the message's attachments array. Use this when calling /me/messages/calendar/apply.",
            "type": "integer"
          },
          "method": {
            "description": "iTIP METHOD value.",
            "type": "string",
            "enum": ["REQUEST", "REPLY", "CANCEL", "COUNTER", "PUBLISH", "REFRESH"]
          },
          "eventUid": {
            "type": "string"
          },
          "sequence": {
            "type": "integer"
          },
          "summary": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
