            "enum": ["accept", "tentative", "decline", "apply", "import", "ignore"]
          },
          "targetCalendarId": {
            "description": "Optional. Required for REQUEST + accept/tentative when no existing match. When omitted, the server picks the user's default calendar (or built-in if default is shared).",
